# База данных PostgreSQL
DATABASE_URL="postgresql://username:password@localhost:5432/feedback360"

# JWT секрет для аутентификации
JWT_SECRET="your-super-secret-jwt-key-here"

# Настройки Mattermost
MATTERMOST_URL="https://your-mattermost-instance.com"
MATTERMOST_TOKEN="your-mattermost-bot-token"
MATTERMOST_WEBHOOK_URL="https://your-mattermost-instance.com/hooks/webhook-id"

# Настройки приложения
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# Дополнительные настройки
NODE_ENV="development"
PORT=3000 